# ==========================================
# Virtual Environment
# ==========================================

.venv/
venv/
env/

# ==========================================
# Python
# ==========================================

__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Jupyter Notebook
# ==========================================

.ipynb_checkpoints/

# ==========================================
# Machine Learning Models
# ==========================================
# Keep deployment model files in GitHub.
# If you create temporary experiment models elsewhere,
# add those paths explicitly instead of ignoring all .pkl files.

# ==========================================
# Data Files
# (Raw and processed datasets should never
# be pushed to GitHub)
# ==========================================

data/raw/*
data/interim/*
data/processed/*

# Keep the folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# ==========================================
# Logs
# ==========================================

*.log

# ==========================================
# VS Code
# ==========================================

.vscode/

# ==========================================
# Operating System Files
# ==========================================

.DS_Store
Thumbs.db

# ==========================================
# Streamlit
# ==========================================

.streamlit/secrets.toml

# ==========================================
# Miscellaneous
# ==========================================

*.tmp
*.bak